# Mosaic runtime configuration
# Copy this file to .env and adjust values as needed.

# Size of each piece in output mosaic pixels
MOSAIC_BLOCK_SIZE_PX=50

# Matching detail resolution (lower is faster, higher is more accurate)
MOSAIC_BLOCK_MATCH_RES=20

# Enlargement factor for input before block processing
MOSAIC_ENLARGEMENT=4

# Blend level of original image over mosaic, from 0.0 to 1.0
MOSAIC_OVERLAY_ALPHA=0.5

# Default output filename when CLI output argument is omitted
MOSAIC_DEFAULT_OUT_FILE=output.jpeg

